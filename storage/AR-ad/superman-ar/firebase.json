{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "assets/supergirl.usdz",
      "assets/supergirl.original.usdz"
    ],
    "headers": [
      {
        "source": "**/*.@(glb|mp4|png|jpg|jpeg|webp)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
        ]
      },
      {
        "source": "**/*.usdz",
        "headers": [
          { "key": "Content-Type", "value": "model/vnd.usdz+zip" },
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
